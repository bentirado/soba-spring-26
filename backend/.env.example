# Local development database. Production can use a Supabase/Render Postgres URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/soba_db

# Local convenience only. Production should set this to false and run Alembic migrations.
AUTO_CREATE_TABLES=true

# Comma-separated frontend origins allowed to call the backend in staging/production.
FRONTEND_ORIGINS=https://soba-demo.vercel.app

# Optional for local dashboard browsing. Required for AI insight buttons.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini if omitted.
OPENAI_INSIGHT_MODEL=gpt-4o-mini

# Optional. Required only for sending event emails through Gmail.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Required for protected API routes once Supabase Auth is enabled.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional. Required only if your Supabase project uses legacy HS256 tokens.
SUPABASE_JWT_SECRET=
